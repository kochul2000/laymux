{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/packages/api/schema.json",
  "productName": "Laymux",
  "version": "0.3.1",
  "identifier": "com.laymux.app",
  "build": {
    "frontendDist": "../ui/dist",
    "beforeDevCommand": "cd ui && npm run dev",
    "beforeBuildCommand": "cd ui && npm run build",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Laymux",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
